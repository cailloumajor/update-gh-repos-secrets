{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "semanticCommits": "enabled",
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "minimumReleaseAge": "14 days"
    }
  ]
}
